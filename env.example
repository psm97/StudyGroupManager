# 이 파일을 .env 로 복사한 뒤 실제 값을 채워넣으세요.
# .env 는 .gitignore 에 포함되어 있어 저장소에 올라가지 않습니다.

# Django (python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())" 로 생성)
DJANGO_SECRET_KEY=your_django_secret_key_here
DEBUG=True

# Database (PostgreSQL)
DB_NAME=studygroup_db
DB_USER=studygroup_user
DB_PASSWORD=your_db_password_here
DB_HOST=localhost
DB_PORT=5432

# Google OAuth 2.0 (Google Cloud Console > 사용자 인증 정보에서 발급)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Google AI (Google AI Studio에서 발급)
GOOGLE_API_KEY=your_google_api_key_here

# 앱 URL (배포 시 실제 도메인으로 변경)
SITE_URL=http://localhost:3000

# Next.js ↔ Django 내부 인증 키 (openssl rand -hex 32 로 생성)
INTERNAL_API_KEY=your_internal_api_key_here
